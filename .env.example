# Copy to .env and set real Postgres connection strings.
#
# DATABASE_URL = POOLED connection (used by the app at runtime / on Vercel).
# DIRECT_URL   = DIRECT (unpooled) connection (used by `prisma migrate` / seed).
#
# ── Neon (recommended, free) ──────────────────────────────────────────────
#   DATABASE_URL="postgresql://USER:PASSWORD@ep-xxx-pooler.REGION.aws.neon.tech/DBNAME?sslmode=require&pgbouncer=true"
#   DIRECT_URL="postgresql://USER:PASSWORD@ep-xxx.REGION.aws.neon.tech/DBNAME?sslmode=require"
#
# ── Plain local Postgres ─────────────────────────────────────────────────-
#   DATABASE_URL="postgresql://user:password@localhost:5432/kappabel?schema=public"
#   DIRECT_URL="postgresql://user:password@localhost:5432/kappabel?schema=public"

DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/DBNAME?sslmode=require&pgbouncer=true"
DIRECT_URL="postgresql://USER:PASSWORD@HOST:5432/DBNAME?sslmode=require"
